# Hermes Geral - Desenvolvimento

# Dono autorizado a conversar com o Hermes Geral.
# Use os formatos local e internacional para tolerar payloads diferentes do BotConversa.
HERMES_GERAL_OWNER_PHONES=89994315927,5589994315927

# Banco proprio do Hermes Geral. Nao usar banco pastoral aqui.
HERMES_GERAL_DB_PATH=database/hermes_geral.db

# Modelo/LLM opcional. Se nao configurar, o webhook registra a conversa e responde em modo offline.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Porta local do servico na VPS.
HERMES_GERAL_PORT=5060

# Telegram do Hermes Geral / Desenvolvedor.
TELEGRAM_BOT_TOKEN=

# Opcional: limite por chat_id. Se vazio, o bot responde a qualquer chat que falar com ele.
# Depois de descobrir seu chat_id nos logs ou resposta do bot, preencha para travar.
TELEGRAM_ALLOWED_CHAT_IDS=
